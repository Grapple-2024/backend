# Clerk Auth — get from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/auth/account-type
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/auth/account-type

# Backend API base URL
NEXT_PUBLIC_API_HOST=https://your-backend.example.com

# Public URL of this frontend app (used for QR code generation)
NEXT_PUBLIC_APP_URL=https://grapple-frontend.onrender.com

# Optional: hostname of your S3 bucket for user-uploaded images
# e.g. my-bucket.s3.us-west-2.amazonaws.com
# If omitted, all *.amazonaws.com hosts are allowed by default.
NEXT_PUBLIC_IMAGE_HOST=
